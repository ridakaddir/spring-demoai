{
  "annotations": { "list": [] },
  "editable": true,
  "title": "demoai observability",
  "uid": "demoai-obs",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{uri}} ({{status}})"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM token usage rate (tokens/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (rate(gen_ai_client_token_usage_total[1m]))",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "LLM tokens per request (p50/p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "llm_tokens_per_request_tokens{quantile=~\"0.5|0.95\"}",
          "legendFormat": "{{type}} p{{quantile}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "LLM avg tokens per request",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_tokens_per_request_tokens_sum[5m])) / sum by (type) (rate(llm_tokens_per_request_tokens_count[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "LLM cumulative tokens",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (gen_ai_client_token_usage_total)",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ]
    }
  ]
}
